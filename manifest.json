{
  "id": "Kitsui Hyphenation",
  "name": "Kitsui Hyphenation",
  "version": "1.0.2",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "22.0.0"
  },
  "manifestVersion": 4,
  "entrypoints": [
    {
      "type": "panel",
      "id": "vanilla",
      "minimumSize": {
        "width": 300,
        "height": 400
      },
      "maximumSize": {
        "width": 800,
        "height": 800
      },
      "preferredDockedSize": {
        "width": 350,
        "height": 500
      },
      "preferredFloatingSize": {
        "width": 350,
        "height": 500
      },
      "label": {
        "default": "Kitsui Hyphenation"
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icon.png",
          "scale": [1, 2],
          "theme": ["darkest", "dark", "medium"]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icon.png",
          "scale": [1, 2],
          "theme": ["lightest", "light"]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 48,
      "height": 48,
      "path": "icon.png",
      "scale": [1, 2],
      "theme": ["darkest", "dark", "medium", "lightest", "light", "all"],
      "species": ["pluginList"]
    }
  ]
}
